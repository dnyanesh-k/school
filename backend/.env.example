# Application
APP_NAME="VidyaTrack"
APP_VERSION="0.1.0"
DEBUG=true

# ─── Database ────────────────────────────────────────────────────────────────
# Local development
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/school_db

# Supabase (production) — use the Pgbouncer pooler URL (port 6543, NOT 5432)
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

DB_ECHO=false

# Local dev: pool_size=10, max_overflow=20
# Supabase free tier: pool_size=3, max_overflow=2  (max 60 connections total)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days — users stay logged in like a mobile app

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local: ["http://localhost:3000"]
# Production: ["https://your-app.vercel.app"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Platform admin ───────────────────────────────────────────────────────────
# Created automatically on first backend startup if not already in DB
PLATFORM_ADMIN_EMAIL=admin@vidyatrack.com
PLATFORM_ADMIN_PASSWORD=change-this-password
PLATFORM_ADMIN_NAME=Platform Admin

# ─── Gmail SMTP (forgot-password OTP) ────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Google Account → Security → App passwords → create for "Mail"
# 3. Paste the 16-character app password below (NOT your Gmail login password)
# If unset, OTP is printed to the backend console (dev only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=VidyaTrack
OTP_EXPIRE_MINUTES=10
