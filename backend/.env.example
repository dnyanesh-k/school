# Application
APP_NAME="School ERP"
APP_VERSION="0.1.0"
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/school_db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Security  — replace with a strong random value (e.g. openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# Platform admin — created on first startup if not exists
PLATFORM_ADMIN_EMAIL=admin@vidyatrack.com
PLATFORM_ADMIN_PASSWORD=change-this-password
PLATFORM_ADMIN_NAME=Platform Admin

# Gmail SMTP (for forgot-password OTP)
# 1. Enable 2-Step Verification on the Google account
# 2. Google Account → Security → App passwords → create app password for "Mail"
# 3. Use that 16-character app password below (NOT your Gmail login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=VidyaTrack
OTP_EXPIRE_MINUTES=10
